    datatype: int
    default: 0
    paramtype: plusarg

targets:
  default:
    filesets: [rtl]

  sim_pack_icarus:
    filesets: [rtl_pack, tb_cocotb]
    toplevel: _zkf_pack
    flow: sim
    flow_options:
      tool: icarus
      cocotb_module: test_pack
      timescale: 1ns/1ps
      iverilog_options: [-Wall, -Wno-timescale, -DSIMULATION=1]
    parameters: &float_pack_params
      - WEXP
      - WMAN
      - WEXP_UNBIASED
      - STAGE_OUTPUT
      - EXP_IS_BIASED
      - ASSUME_NO_OVERFLOW
      - ZKF_WEXP
      - ZKF_WMAN
      - ZKF_WEXP_UNBIASED
      - ZKF_STAGE_OUTPUT
      - ZKF_EXP_IS_BIASED
      - ZKF_ASSUME_NO_OVERFLOW
      - ZKF_KIND
      - ZKF_COUNT
      - ZKF_SEED
      - ZKF_CONFIG

  sim_pack_verilator:
    filesets: [rtl_pack, tb_cocotb]
    toplevel: _zkf_pack
    flow: sim
    flow_options:
      tool: verilator
      cocotb_module: test_pack
      verilator_options:
        - --timing
        - -Wno-TIMESCALEMOD
        - -Wno-WIDTHEXPAND
        - -Wno-WIDTHTRUNC
        - -Wno-DECLFILENAME
        - -Wno-UNOPTFLAT
        - -DSIMULATION=1
        - --coverage-line
        - --coverage-toggle
      run_options: [+verilator+coverage+file+coverage.dat]
    parameters: *float_pack_params

  sim_mul_icarus:
    filesets: [rtl_mul, tb_cocotb]
    toplevel: zkf_mul
    flow: sim
    flow_options:
      tool: icarus
      cocotb_module: test_mul
      timescale: 1ns/1ps
      iverilog_options: [-Wall, -Wno-timescale, -DSIMULATION=1]
    parameters: &float_binary_params_sp
      - WEXP
      - WMAN
      - STAGE_INPUT
      - STAGE_PRODUCT
      - WMULTIPLIER
      - STAGE_PACK
      - STAGE_OUTPUT
      - ZKF_WEXP
      - ZKF_WMAN
      - ZKF_KIND
      - ZKF_COUNT
      - ZKF_SEED
      - ZKF_CONFIG
      - ZKF_STAGE_INPUT
      - ZKF_STAGE_PRODUCT
      - ZKF_WMULTIPLIER
      - ZKF_STAGE_PACK
      - ZKF_STAGE_OUTPUT

  sim_mul_verilator:
    filesets: [rtl_mul, tb_cocotb]
    toplevel: zkf_mul
    flow: sim
    flow_options: &verilator_binary_flow
      tool: verilator
      cocotb_module: test_mul
      verilator_options:
        - --timing
        - -Wno-TIMESCALEMOD
        - -Wno-WIDTHEXPAND
        - -Wno-WIDTHTRUNC
        - -Wno-DECLFILENAME
        - -Wno-UNOPTFLAT
        - -DSIMULATION=1
        - --coverage-line
        - --coverage-toggle
      run_options: [+verilator+coverage+file+coverage.dat]
    parameters: *float_binary_params_sp

  sim_add_icarus:
    filesets: [rtl_add, tb_cocotb]
    toplevel: zkf_add
    flow: sim
    flow_options:
      tool: icarus
      cocotb_module: test_add
      timescale: 1ns/1ps
      iverilog_options: [-Wall, -Wno-timescale, -DSIMULATION=1]
    parameters: &float_binary_params_sad
      - WEXP
      - WMAN
      - STAGE_INPUT
      - STAGE_DECODE
      - STAGE_ALIGN
      - STAGE_NORMALIZE
      - STAGE_PACK
      - STAGE_OUTPUT
      - ZKF_WEXP
      - ZKF_WMAN
      - ZKF_KIND
      - ZKF_COUNT
      - ZKF_SEED
      - ZKF_CONFIG
      - ZKF_STAGE_INPUT
      - ZKF_STAGE_DECODE
      - ZKF_STAGE_ALIGN
      - ZKF_STAGE_NORMALIZE
      - ZKF_STAGE_PACK
      - ZKF_STAGE_OUTPUT

  sim_add_verilator:
    filesets: [rtl_add, tb_cocotb]
    toplevel: zkf_add
    flow: sim
    flow_options:
      <<: *verilator_binary_flow
      cocotb_module: test_add
    parameters: *float_binary_params_sad

  sim_fma_icarus:
    filesets: [rtl_fma, tb_cocotb]
    toplevel: zkf_fma
    flow: sim
    flow_options:
      tool: icarus
      cocotb_module: test_fma
      timescale: 1ns/1ps
      iverilog_options: [-Wall, -Wno-timescale, -DSIMULATION=1]
    parameters: &float_fma_params
      - WEXP
      - WMAN
      - STAGE_INPUT
      - STAGE_PRODUCT
      - WMULTIPLIER
      - STAGE_DECODE
      - STAGE_ALIGN
      - STAGE_NORMALIZE
      - STAGE_PACK
      - STAGE_OUTPUT
      - ZKF_WEXP
      - ZKF_WMAN
      - ZKF_KIND
      - ZKF_COUNT
      - ZKF_SEED
      - ZKF_CONFIG
      - ZKF_STAGE_INPUT
      - ZKF_STAGE_PRODUCT
      - ZKF_WMULTIPLIER
      - ZKF_STAGE_DECODE
      - ZKF_STAGE_ALIGN
      - ZKF_STAGE_NORMALIZE
      - ZKF_STAGE_PACK
      - ZKF_STAGE_OUTPUT

  sim_fma_verilator:
    filesets: [rtl_fma, tb_cocotb]
    toplevel: zkf_fma
    flow: sim
    flow_options:
      <<: *verilator_binary_flow
      cocotb_module: test_fma
    parameters: *float_fma_params

  sim_div_icarus:
    filesets: [rtl_div, tb_cocotb]
    toplevel: zkf_div
    flow: sim
    flow_options:
      tool: icarus
      cocotb_module: test_div
      timescale: 1ns/1ps
      iverilog_options: [-Wall, -Wno-timescale, -DSIMULATION=1]
    parameters: &float_binary_params_si
      - WEXP
      - WMAN
      - STAGE_INPUT
      - STAGE_PACK
      - STAGE_OUTPUT
      - ZKF_WEXP
      - ZKF_WMAN
      - ZKF_KIND
      - ZKF_COUNT
      - ZKF_SEED
      - ZKF_CONFIG
      - ZKF_STAGE_INPUT
