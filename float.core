CAPI=2:
name: zubax:kulibin:float:0
description: Simple deterministic floating-point helpers

filesets:
  rtl:
    files:
      - hdl/_zkf_pack.v
      - hdl/zkf_pipe.v
      - hdl/_zkf_normshift.v
      - hdl/_zkf_rshift_sticky.v
      - hdl/_zkf_div_core.v
      - hdl/zkf_mul.v
      - hdl/zkf_add.v
      - hdl/zkf_div.v
      - hdl/zkf_abs.v
      - hdl/zkf_neg.v
      - hdl/zkf_is_finite.v
      - hdl/zkf_saturate.v
      - hdl/zkf_cmp_comb.v
      - hdl/zkf_cmp.v
      - hdl/zkf_sort.v
      - hdl/zkf_addsub.v
      - hdl/zkf_mul_ilog2_const.v
      - hdl/zkf_mul_ilog2.v
      - hdl/zkf_fma.v
      - hdl/_zkf_horner.v
      - hdl/_zkf_pmul.v
      - hdl/_zkf_to_fixpoint.v
      - hdl/_zkf_fixed_to_float.v
      - hdl/_tables/_zkf_exp2_m16.v
      - hdl/_tables/_zkf_exp2_m18.v
      - hdl/_tables/_zkf_exp2_m24.v
      - hdl/_tables/_zkf_exp2_m27.v
      - hdl/_tables/_zkf_exp2_m32.v
      - hdl/_tables/_zkf_exp2_m36.v
      - hdl/_tables/_zkf_exp2_m48.v
      - hdl/_tables/_zkf_exp2_m53.v
      - hdl/_tables/_zkf_log2_m16.v
      - hdl/_tables/_zkf_log2_m18.v
      - hdl/_tables/_zkf_log2_m24.v
      - hdl/_tables/_zkf_log2_m27.v
      - hdl/_tables/_zkf_log2_m32.v
      - hdl/_tables/_zkf_log2_m36.v
      - hdl/_tables/_zkf_log2_m48.v
      - hdl/_tables/_zkf_log2_m53.v
      - hdl/zkf_exp2.v
      - hdl/zkf_log2.v
      - hdl/zkf_round.v
    file_type: verilogSource

  rtl_pack:
    files:
      - hdl/zkf_pipe.v
      - hdl/_zkf_pack.v
    file_type: verilogSource

  rtl_mul:
    files:
      - hdl/_zkf_pack.v
      - hdl/zkf_pipe.v
      - hdl/_zkf_pmul.v
      - hdl/zkf_mul.v
    file_type: verilogSource

  rtl_add:
    files:
      - hdl/_zkf_pack.v
      - hdl/zkf_pipe.v
      - hdl/_zkf_normshift.v
      - hdl/_zkf_rshift_sticky.v
      - hdl/zkf_add.v
    file_type: verilogSource

  rtl_fma:
    files:
      - hdl/_zkf_pack.v
      - hdl/zkf_pipe.v
      - hdl/_zkf_pmul.v
      - hdl/_zkf_normshift.v
      - hdl/_zkf_rshift_sticky.v
      - hdl/zkf_fma.v
    file_type: verilogSource

  rtl_div:
    files:
      - hdl/_zkf_pack.v
      - hdl/zkf_pipe.v
      - hdl/_zkf_div_core.v
      - hdl/zkf_div.v
    file_type: verilogSource

  rtl_pipe:
    files:
      - hdl/zkf_pipe.v
    file_type: verilogSource

  rtl_normshift:
    files:
      - hdl/_zkf_normshift.v
    file_type: verilogSource

  rtl_rshift:
    files:
      - hdl/_zkf_rshift_sticky.v
    file_type: verilogSource

  rtl_abs:
    files:
      - hdl/zkf_abs.v
    file_type: verilogSource

  rtl_neg:
    files:
      - hdl/zkf_neg.v
    file_type: verilogSource

  rtl_is_finite:
    files:
      - hdl/zkf_is_finite.v
    file_type: verilogSource

  rtl_saturate:
    files:
      - hdl/zkf_saturate.v
    file_type: verilogSource

  # zkf_cmp_comb is intentionally tested through registered public wrappers below:
  # zkf_cmp covers its flags directly and zkf_sort covers consumers of the ordering decision.
  rtl_cmp:
    files:
      - hdl/zkf_pipe.v
      - hdl/zkf_cmp_comb.v
      - hdl/zkf_cmp.v
    file_type: verilogSource

  rtl_sort:
    files:
      - hdl/zkf_pipe.v
      - hdl/zkf_cmp_comb.v
      - hdl/zkf_sort.v
    file_type: verilogSource

  rtl_addsub:
    files:
      - hdl/_zkf_pack.v
      - hdl/zkf_pipe.v
      - hdl/_zkf_normshift.v
      - hdl/_zkf_rshift_sticky.v
      - hdl/zkf_add.v
      - hdl/zkf_addsub.v
    file_type: verilogSource

  rtl_mul_ilog2_const:
    files:
      - hdl/zkf_pipe.v
      - hdl/zkf_mul_ilog2_const.v
    file_type: verilogSource

  rtl_mul_ilog2:
    files:
      - hdl/zkf_pipe.v
      - hdl/zkf_mul_ilog2.v
    file_type: verilogSource

  rtl_from_int:
    files:
      - hdl/_zkf_pack.v
      - hdl/zkf_pipe.v
      - hdl/_zkf_normshift.v
      - hdl/_zkf_fixed_to_float.v
      - hdl/zkf_from_int.v
    file_type: verilogSource

  rtl_to_int:
    files:
      - hdl/zkf_pipe.v
      - hdl/_zkf_rshift_sticky.v
      - hdl/_zkf_to_fixpoint.v
      - hdl/zkf_to_int.v
    file_type: verilogSource

  rtl_resize:
    files:
      - hdl/_zkf_pack.v
      - hdl/zkf_pipe.v
      - hdl/zkf_resize.v
    file_type: verilogSource

  rtl_round:
    files:
      - hdl/_zkf_pack.v
      - hdl/zkf_pipe.v
      - hdl/zkf_round.v
    file_type: verilogSource

  rtl_exp2:
    files:
      - hdl/_zkf_pack.v
      - hdl/zkf_pipe.v
      - hdl/_zkf_pmul.v
      - hdl/_zkf_rshift_sticky.v
      - hdl/_zkf_to_fixpoint.v
      - hdl/_zkf_horner.v
      - hdl/_tables/_zkf_exp2_m16.v
      - hdl/_tables/_zkf_exp2_m18.v
      - hdl/_tables/_zkf_exp2_m24.v
      - hdl/_tables/_zkf_exp2_m27.v
      - hdl/_tables/_zkf_exp2_m32.v
      - hdl/_tables/_zkf_exp2_m36.v
      - hdl/_tables/_zkf_exp2_m48.v
      - hdl/_tables/_zkf_exp2_m53.v
      - hdl/zkf_exp2.v
    file_type: verilogSource

  rtl_log2:
    files:
      - hdl/_zkf_pack.v
      - hdl/zkf_pipe.v
      - hdl/_zkf_pmul.v
      - hdl/_zkf_normshift.v
      - hdl/_zkf_fixed_to_float.v
      - hdl/_zkf_horner.v
      - hdl/_tables/_zkf_log2_m16.v
      - hdl/_tables/_zkf_log2_m18.v
      - hdl/_tables/_zkf_log2_m24.v
      - hdl/_tables/_zkf_log2_m27.v
      - hdl/_tables/_zkf_log2_m32.v
      - hdl/_tables/_zkf_log2_m36.v
      - hdl/_tables/_zkf_log2_m48.v
      - hdl/_tables/_zkf_log2_m53.v
      - hdl/zkf_log2.v
    file_type: verilogSource

  rtl_sincos:
    files:
      - hdl/_zkf_pack.v
      - hdl/zkf_pipe.v
      - hdl/_zkf_normshift.v
      - hdl/_zkf_fixed_to_float.v
      - hdl/_zkf_pmul.v
      - hdl/_zkf_cordic.v
      - hdl/_tables/_zkf_cordic_m16.v
      - hdl/_tables/_zkf_cordic_m18.v
      - hdl/_tables/_zkf_cordic_m24.v
      - hdl/_tables/_zkf_cordic_m27.v
      - hdl/_tables/_zkf_cordic_m32.v
      - hdl/_tables/_zkf_cordic_m36.v
      - hdl/_tables/_zkf_cordic_m48.v
      - hdl/_tables/_zkf_cordic_m53.v
      - hdl/zkf_sincos.v
    file_type: verilogSource

  rtl_atan2:
    files:
      - hdl/_zkf_pack.v
      - hdl/zkf_pipe.v
      - hdl/_zkf_normshift.v
      - hdl/_zkf_fixed_to_float.v
      - hdl/_zkf_cordic.v
      - hdl/_tables/_zkf_cordic_m16.v
      - hdl/_tables/_zkf_cordic_m18.v
      - hdl/_tables/_zkf_cordic_m24.v
      - hdl/_tables/_zkf_cordic_m27.v
      - hdl/_tables/_zkf_cordic_m32.v
      - hdl/_tables/_zkf_cordic_m36.v
      - hdl/_tables/_zkf_cordic_m48.v
      - hdl/_tables/_zkf_cordic_m53.v
      - hdl/_zkf_div_core.v
      - hdl/_zkf_pmul.v
      - hdl/zkf_atan2.v
    file_type: verilogSource

  pmul_unit:
    files:
      - hdl/_zkf_pmul.v
      - tb/_zkf_pmul_tb.v
    file_type: verilogSource

  tb_mul_ilog2_const_wrap:
    files:
      - tb/zkf_mul_ilog2_const_wrap.v
    file_type: verilogSource

  tb_cocotb:
    # The zkf reference-model package (float/zkf/) is resolved via PYTHONPATH (see test_float_matrix.py and Makefile),
    # not staged here. Only the cocotb harness modules are listed.
    files:
      - tb/zkf_params.py:
          file_type: user
      - tb/zkf_latency.py:
          file_type: user
      - tb/zkf_stream.py:
          file_type: user
      - tb/zkf_operands.py:
          file_type: user
      - tb/zkf_results.py:
          file_type: user
      - tb/test_pack.py:
          file_type: user
      - tb/test_mul.py:
          file_type: user
      - tb/test_add.py:
          file_type: user
      - tb/test_fma.py:
          file_type: user
      - tb/test_div.py:
          file_type: user
      - tb/test_pipe.py:
          file_type: user
      - tb/test_abs.py:
          file_type: user
      - tb/test_neg.py:
          file_type: user
      - tb/test_is_finite.py:
          file_type: user
      - tb/test_saturate.py:
          file_type: user
      - tb/test_addsub.py:
          file_type: user
      - tb/test_cmp.py:
          file_type: user
      - tb/test_sort.py:
          file_type: user
      - tb/test_mul_ilog2_const.py:
          file_type: user
      - tb/test_mul_ilog2.py:
          file_type: user
      - tb/test_from_int.py:
          file_type: user
      - tb/test_to_int.py:
          file_type: user
      - tb/test_resize.py:
          file_type: user
      - tb/test_round.py:
          file_type: user
      - tb/test_exp2.py:
          file_type: user
      - tb/test_log2.py:
          file_type: user
      - tb/test_sincos.py:
          file_type: user
      - tb/test_atan2.py:
          file_type: user
      - tb/test_properties.py:
          file_type: user

parameters:
  WEXP:
    datatype: int
    default: 6
    paramtype: vlogparam
  WMAN:
    datatype: int
    default: 18
    paramtype: vlogparam
  WEXP_UNBIASED:
    datatype: int
    default: 8
    paramtype: vlogparam
  W:
    datatype: int
    default: 1
    paramtype: vlogparam
  N:
    datatype: int
    default: 0
    paramtype: vlogparam
  ZKF_WEXP:
    datatype: int
    default: 6
    paramtype: plusarg
  ZKF_WMAN:
    datatype: int
    default: 18
    paramtype: plusarg
  ZKF_WEXP_UNBIASED:
    datatype: int
    default: 8
    paramtype: plusarg
  ZKF_KIND:
    datatype: str
    default: directed
    paramtype: plusarg
  ZKF_COUNT:
    datatype: int
    default: 0
    paramtype: plusarg
  ZKF_SEED:
    datatype: str
    default: "0"
    paramtype: plusarg
  ZKF_CONFIG:
    datatype: str
    default: default
    paramtype: plusarg
  ZKF_PIPE_W:
    datatype: int
    default: 1
    paramtype: plusarg
  ZKF_PIPE_N:
    datatype: int
    default: 0
    paramtype: plusarg
  WINT:
    datatype: int
    default: 32
    paramtype: vlogparam
  ZKF_WINT:
    datatype: int
    default: 32
    paramtype: plusarg
  WK:
    datatype: int
    default: 7
    paramtype: vlogparam
  ZKF_WK:
    datatype: int
    default: 7
    paramtype: plusarg
  WEXP_IN:
    datatype: int
    default: 6
    paramtype: vlogparam
  WMAN_IN:
    datatype: int
    default: 18
    paramtype: vlogparam
  WEXP_OUT:
    datatype: int
    default: 5
    paramtype: vlogparam
  WMAN_OUT:
    datatype: int
    default: 11
    paramtype: vlogparam
  ZKF_WEXP_IN:
    datatype: int
    default: 6
    paramtype: plusarg
  ZKF_WMAN_IN:
    datatype: int
    default: 18
    paramtype: plusarg
  ZKF_WEXP_OUT:
    datatype: int
    default: 5
    paramtype: plusarg
  ZKF_WMAN_OUT:
    datatype: int
    default: 11
    paramtype: plusarg
  UNROLL100:
    datatype: int
    default: 100
    paramtype: vlogparam
  ZKF_UNROLL100:
    datatype: int
    default: 100
    paramtype: plusarg
  PARALLEL:
    datatype: int
    default: 0
    paramtype: vlogparam
  ZKF_PARALLEL:
    datatype: int
    default: 0
    paramtype: plusarg
  STAGE_INPUT:
    datatype: int
    default: 0
    paramtype: vlogparam
  ZKF_STAGE_INPUT:
    datatype: int
    default: 0
    paramtype: plusarg
  STAGE_REDUCE:
    datatype: int
    default: 0
    paramtype: vlogparam
  ZKF_STAGE_REDUCE:
    datatype: int
    default: 0
    paramtype: plusarg
  STAGE_PRODUCT:
    datatype: int
    default: 0
    paramtype: vlogparam
  ZKF_STAGE_PRODUCT:
    datatype: int
    default: 0
    paramtype: plusarg
  STAGE_PRODUCT_FINAL:
    datatype: int
    default: 0
    paramtype: vlogparam
  ZKF_STAGE_PRODUCT_FINAL:
    datatype: int
    default: 0
    paramtype: plusarg
  WMULTIPLIER:
    datatype: int
    default: 0
    paramtype: vlogparam
  ZKF_WMULTIPLIER:
    datatype: int
    default: 0
    paramtype: plusarg
  STAGE_OUTPUT:
    datatype: int
    default: 0
    paramtype: vlogparam
  ZKF_STAGE_OUTPUT:
    datatype: int
    default: 0
    paramtype: plusarg
  STAGE_ALIGN:
    datatype: int
    default: 0
    paramtype: vlogparam
  ZKF_STAGE_ALIGN:
    datatype: int
    default: 0
    paramtype: plusarg
  STAGE_DECODE:
    datatype: int
    default: 0
    paramtype: vlogparam
  ZKF_STAGE_DECODE:
    datatype: int
    default: 0
    paramtype: plusarg
  STAGE_NORMALIZE:
    datatype: int
    default: 0
    paramtype: vlogparam
  ZKF_STAGE_NORMALIZE:
    datatype: int
    default: 0
    paramtype: plusarg
  STAGE_NORMALIZE_OUTPUT:
    datatype: int
    default: 0
    paramtype: vlogparam
  ZKF_STAGE_NORMALIZE_OUTPUT:
    datatype: int
    default: 0
